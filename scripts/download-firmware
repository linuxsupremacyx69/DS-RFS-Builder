#!/bin/bash

# Enable strict mode:
# -e: Exit immediately if any command fails (non-zero exit code)
# -u: Error and exit when using undefined variables
# -o pipefail: If any command in a pipeline fails, the entire pipeline fails
set -euo pipefail

# Marker file path, used to determine if firmware processing is complete to prevent duplicate execution
MARKER_FILE="/var/lib/.fw-setup-completed"
FIRMWARE_DIR="/lib/firmware"

# Define variables for terminal output colors to make prompt information more eye-catching
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Error handling function: prints a red error message and exits the script
error_exit() {
    echo -e "${RED}Error: $1${NC}" >&2
    # If the script errors out midway, delete the marker file that might have been left behind for safety
    rm -f "$MARKER_FILE"
    exit 1
}

# Permission check: ensure the script is run with root privileges (sudo)
if [ "$EUID" -ne 0 ]; then
    error_exit "This script must be run as root (please use sudo)"
fi

echo -e "${GREEN}Starting firmware configuration...${NC}"
echo ""

# ---------------------------------------------------------
# Step 0: Check and install the zstd decompression tool
# ---------------------------------------------------------
echo -e "${YELLOW}Step 0: Checking for zstd decompression tool...${NC}"
if ! command -v zstd >/dev/null 2>&1; then
    echo -e "${YELLOW}  zstd not found, installing...${NC}"
    echo ""
    if ! apt-get update; then
        error_exit "Failed to update package list (to install zstd)"
    fi
    echo ""
    if ! apt-get install -y zstd; then
        error_exit "Failed to install zstd package"
    fi
    echo ""
    echo -e "${GREEN}✓ zstd installation complete${NC}"
else
    echo -e "${GREEN}✓ zstd is already installed${NC}"
fi
echo ""

# ---------------------------------------------------------
# Step 1: Install the linux-firmware package
# ---------------------------------------------------------
echo -e "${YELLOW}Step 1: Installing linux-firmware (Official Linux firmware repository)...${NC}"
echo ""
if ! apt-get update; then
    error_exit "Failed to update package list"
fi
echo ""
if ! apt-get install -y linux-firmware; then
    error_exit "Failed to install linux-firmware package"
fi
echo ""

# Verify if the firmware directory was successfully created
if [ ! -d "$FIRMWARE_DIR" ]; then
    error_exit "Firmware directory $FIRMWARE_DIR does not exist"
fi

echo -e "${GREEN}✓ linux-firmware installation complete${NC}"
echo ""

# ---------------------------------------------------------
# Step 2: Find and decompress all real .zst archives (excluding symlinks)
# ---------------------------------------------------------
echo -e "${YELLOW}Step 2: Decompressing .zst firmware archives...${NC}"
echo ""
decompressed_count=0

# Create two temporary files to store search results (better compatibility than direct process substitution syntax)
TEMP_FILE=$(mktemp)
TEMP_FILE2=$(mktemp)
# Use trap to ensure the script cleans up these two temporary files no matter how it ends
trap "rm -f '$TEMP_FILE' '$TEMP_FILE2'" EXIT

# Find all "regular files" ending in .zst (-type f, excluding symlinks)
# -print0 combined with read -d '' perfectly handles extreme cases like filenames with spaces
find "$FIRMWARE_DIR" -type f -name "*.zst" -print0 2>/dev/null > "$TEMP_FILE" || true

while IFS= read -r -d '' zst_file; do
    # Double-check to skip symlinks (double insurance)
    if [ -L "$zst_file" ]; then
        continue
    fi

    # Get the target filename without the .zst suffix (e.g., wifi.bin.zst -> wifi.bin)
    target_file="${zst_file%.zst}"

    # If the decompressed file already exists, skip it
    if [ -e "$target_file" ]; then
        echo -e "${YELLOW}  Skipping $zst_file (Target file already exists)${NC}"
        continue
    fi

    # Execute decompression (-d stands for decompress, -o specifies output path)
    if zstd -d "$zst_file" -o "$target_file" 2>/dev/null; then
        # Verify if decompression was successful
        if [ -f "$target_file" ]; then
            # After successful decompression, completely delete the original .zst archive to save space
            rm -f "$zst_file"
            decompressed_count=$((decompressed_count + 1))
        else
            error_exit "Failed to decompress $zst_file: Target file was not created"
        fi
    else
        error_exit "Unable to decompress $zst_file"
    fi
done < "$TEMP_FILE"

echo ""
echo -e "${GREEN}✓ A total of $decompressed_count archives were decompressed${NC}"
echo ""

# ---------------------------------------------------------
# Step 3: Handle symlinks ending in .zst (Symlinks)
# ---------------------------------------------------------
# This part is the most complex because after decompressing the original files, the symlinks pointing to .zst are all broken and must be redirected
echo -e "${YELLOW}Step 3: Processing .zst symlinks...${NC}"
echo ""
symlink_count=0

# Find all "symlinks" ending in .zst (-type l)
find "$FIRMWARE_DIR" -type l -name "*.zst" -print0 2>/dev/null > "$TEMP_FILE2" || true

while IFS= read -r -d '' symlink_path; do
    # Get the target path this symlink currently points to
    target_path=$(readlink "$symlink_path")

    # If it is a relative path, calculate its absolute path
    if [[ "$target_path" != /* ]]; then
        symlink_dir=$(dirname "$symlink_path")
        target_path=$(realpath -m "$symlink_dir/$target_path")
    fi

    # Try to find the real file target in multiple possible locations
    original_target="$target_path"
    found_target=""

    # Check if the originally pointed path exists
    if [ -e "$target_path" ]; then
        found_target="$target_path"
    fi

    # If it points to /usr/lib/firmware/, try finding it in /lib/firmware/ (handle Debian's usr-merge issue)
    if [ -z "$found_target" ] && [[ "$target_path" == /usr/lib/firmware/* ]]; then
        alt_path="/lib/firmware/${target_path#/usr/lib/firmware/}"
        if [ -e "$alt_path" ]; then
            found_target="$alt_path"
        fi
    fi

    # If still not found, and the target is a .zst, check if its corresponding "decompressed version" exists
    if [ -z "$found_target" ] && [[ "$target_path" == *.zst ]]; then
        # Check the decompressed version in the original directory
        decompressed_path="${target_path%.zst}"
        if [ -e "$decompressed_path" ]; then
            found_target="$decompressed_path"
        fi

        # Check the decompressed version in the /lib/firmware/ directory
        if [ -z "$found_target" ] && [[ "$target_path" == /usr/lib/firmware/* ]]; then
            alt_decompressed="/lib/firmware/${decompressed_path#/usr/lib/firmware/}"
            if [ -e "$alt_decompressed" ]; then
                found_target="$alt_decompressed"
            fi
        fi
    fi

    # If still not found, try extracting the relative path to force a search in /lib/firmware
    if [ -z "$found_target" ] && [[ "$target_path" != /lib/firmware/* ]]; then
        if [[ "$target_path" == /* ]]; then
            rel_path="${target_path#/}"
            alt_path="/lib/firmware/$rel_path"
            if [ -e "$alt_path" ]; then
                found_target="$alt_path"
            fi
        fi
    fi

    # If exhaustively searching still yields nothing, it's a dead link, skip it
    if [ -z "$found_target" ]; then
        echo -e "${YELLOW}  Warning: Symlink $symlink_path points to non-existent target $original_target${NC}"
        continue
    fi

    target_path="$found_target"

    # If the target itself is also a symlink, parse it recursively until the final real file is found
    # (The internal search logic is identical to the search method above)
    while [ -L "$target_path" ]; do
        link_target=$(readlink "$target_path")
        if [[ "$link_target" != /* ]]; then
            link_dir=$(dirname "$target_path")
            link_target=$(realpath -m "$link_dir/$link_target")
        fi

        original_link="$link_target"
        found_link=""

        if [ -e "$link_target" ]; then found_link="$link_target"; fi

        if [ -z "$found_link" ] && [[ "$link_target" == /usr/lib/firmware/* ]]; then
            alt_path="/lib/firmware/${link_target#/usr/lib/firmware/}"
            if [ -e "$alt_path" ]; then found_link="$alt_path"; fi
        fi

        if [ -z "$found_link" ] && [[ "$link_target" == *.zst ]]; then
            decompressed_path="${link_target%.zst}"
            if [ -e "$decompressed_path" ]; then
                found_link="$decompressed_path"
            fi

            if [ -z "$found_link" ] && [[ "$link_target" == /usr/lib/firmware/* ]]; then
                alt_decompressed="/lib/firmware/${decompressed_path#/usr/lib/firmware/}"
                if [ -e "$alt_decompressed" ]; then
                    found_link="$alt_decompressed"
                fi
            fi
        fi

        if [ -z "$found_link" ]; then
            # If unable to parse, abort and use the currently obtainable target
            break
        fi
        target_path="$found_link"
    done

    # If the final target tracked down is still a .zst file, decompress it here
    if [[ "$target_path" == *.zst ]] && [ -f "$target_path" ] && [ ! -L "$target_path" ]; then
        decompressed_target="${target_path%.zst}"

        if [ -e "$decompressed_target" ]; then
            echo -e "${YELLOW}  Target has already been decompressed: $decompressed_target${NC}"
            target_path="$decompressed_target"
        else
            if zstd -d "$target_path" -o "$decompressed_target" 2>/dev/null; then
                if [ -f "$decompressed_target" ]; then
                    rm -f "$target_path"
                    target_path="$decompressed_target"
                else
                    error_exit "Failed to decompress final target $target_path"
                fi
            else
                error_exit "Failed to decompress final target $target_path"
            fi
        fi
    fi

    # Calculate the new symlink path (removing the .zst suffix)
    new_symlink_path="${symlink_path%.zst}"

    # If the new symlink path is already occupied by a real file, skip it
    if [ -e "$new_symlink_path" ] && [ ! -L "$new_symlink_path" ]; then
        echo -e "${YELLOW}  Skipping $symlink_path (Target file already exists)${NC}"
        continue
    fi

    # Calculate the [relative path] from the new symlink location to the real target file
    new_symlink_dir=$(dirname "$new_symlink_path")
    relative_target=$(realpath --relative-to="$new_symlink_dir" "$target_path" 2>/dev/null || echo "$target_path")

    # Delete the old crippled symlink with the .zst suffix
    rm -f "$symlink_path"

    # Create the new symlink (without the .zst suffix) pointing to the decompressed real file
    if ln -sf "$relative_target" "$new_symlink_path"; then
        symlink_count=$((symlink_count + 1))
    else
        error_exit "Unable to create symlink $new_symlink_path -> $relative_target"
    fi

done < "$TEMP_FILE2"

echo ""
echo -e "${GREEN}✓ A total of $symlink_count symlinks were processed${NC}"
echo ""

# ---------------------------------------------------------
# Step 4: Create completion marker file
# ---------------------------------------------------------
echo -e "${YELLOW}Step 4: Creating completion marker...${NC}"
echo ""
if mkdir -p "$(dirname "$MARKER_FILE")" && touch "$MARKER_FILE"; then
    echo -e "${GREEN}✓ Marker file created: $MARKER_FILE${NC}"
else
    error_exit "Failed to create marker file"
fi
echo ""

# Perfect ending
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}Firmware configuration completed successfully!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  Decompressed archives: $decompressed_count"
echo -e "  Processed symlinks: $symlink_count"
echo -e "  Completion marker file: $MARKER_FILE"
echo ""

exit 0
